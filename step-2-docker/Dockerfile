# ==============================================================================
# DOCKERFILE — инструкция по сборке образа контейнера
# ==============================================================================
# Это multi-stage build (многоэтапная сборка) — продвинутый паттерн Docker.
# Образ собирается в два этапа:
#   Этап 1 (downloader): скачивает исходники приложения
#   Этап 2 (final):      собирает финальный образ только с тем, что нужно для работы
#
# Зачем два этапа?
# Инструменты сборки (git, компиляторы и т.д.) нужны только во время сборки.
# В финальный образ они не попадают — образ остаётся маленьким и безопасным.
# ==============================================================================


# ==============================================================================
# ЭТАП 1: Загрузка исходников
# ==============================================================================
# AS downloader — имя этапа, чтобы ссылаться на него из следующего этапа
FROM alpine:3.15 AS downloader

# ARG — переменная, доступная только во время сборки образа (не в runtime).
# Здесь — адрес репозитория с HTML-шаблоном. Можно переопределить при сборке:
#   docker build --build-arg TEMPLATE_REPO=https://... .
ARG TEMPLATE_REPO="https://github.com/isaevdo/selectel-mks-workshop.git"

# Устанавливаем git и клонируем репозиторий с шаблоном сайта в /tmp.
# Весь этот слой (git + репозиторий) останется только в этом этапе.
RUN apk add git \
    && git clone --depth=1 ${TEMPLATE_REPO} /tmp/repo


# ==============================================================================
# ЭТАП 2: Финальный образ
# ==============================================================================
# --platform linux/amd64 — серверы Selectel работают на x86-64.
# Ноутбуки Apple M1/M2/M3 — на ARM. Без этого флага образ не запустится в кластере.
FROM --platform=linux/amd64 nginx:1.23

# ARG — какую папку из репозитория взять. В репо может быть несколько шаблонов.
ARG TEMPLATE_NAME="coffee-shop-html-template"

# COPY --from=downloader — копируем файлы из первого этапа в финальный образ.
# nginx раздаёт файлы из /usr/share/nginx/html — туда и кладём наш сайт.
COPY --from=downloader /tmp/repo/web-templates/${TEMPLATE_NAME} /usr/share/nginx/html

# Документируем порт — nginx слушает 80
EXPOSE 80

# Запускаем nginx в foreground (контейнер живёт, пока жив процесс)
CMD ["nginx", "-g", "daemon off;"]
