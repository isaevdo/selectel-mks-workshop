# ==============================================================================
# ПРИМЕР ФАЙЛА ПЕРЕМЕННЫХ
# ==============================================================================
# 1. Скопируйте: cp terraform.tfvars.example terraform.tfvars
# 2. Заполните своими значениями
# 3. НЕ коммитьте terraform.tfvars в git — там пароли!
# ==============================================================================

# --- Сервисный пользователь Selectel ---
# ID аккаунта: только цифры из правого верхнего угла панели (например, 123456, без суффикса)
selectel_domain = "123456"

# Сервисный пользователь Selectel:
# Управление доступами → Сервисные пользователи → Создать сервисного пользователя
# Роли на уровне аккаунта (обе обязательны):
#   - Member    — для создания проекта и управления ресурсами
#   - iam.admin — для создания сервисных пользователей через Terraform
selectel_username = "terraform-user"
selectel_password = "your-selectel-password"

# --- Сервисный пользователь для OpenStack ---
# Terraform создаст его автоматически внутри проекта.
# ВАЖНО: пароль должен содержать минимум 20 символов,
# заглавные и строчные буквы, цифры и спецсимволы.
# Пример: "W0rksh0p#S3cur3!2024xy"
openstack_username = "workshop-openstack-user"
openstack_password = "W0rksh0p#S3cur3!2024xy"

# --- Настройки проекта и кластера (можно оставить по умолчанию) ---
project_name = "workshop-coffee-shop"
cluster_name = "coffee-shop-cluster"
region       = "ru-9"

# --- Тип узла ---
# Проверьте актуальный flavor_id в панели:
# Kubernetes → Создать кластер → Создать группу узлов → тип узла
node_count     = 1
node_flavor_id = "1013"

registry_name = "coffee-shop-registry"
